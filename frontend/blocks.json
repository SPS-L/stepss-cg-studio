{
  "algeq": {
    "label": "Algebraic Equation",
    "category": "Algebraic",
    "description": "Implicit algebraic equation: f(x) = 0. Write the residual expression.",
    "inputs": [],
    "outputs": ["residual"],
    "color": "#6b7280",
    "dsl_lines": ["{{expr}}"],
    "args": [
      {"name": "expr", "label": "Residual expression (= 0)", "type": "expr", "default": ""}
    ]
  },
  "tf1p": {
    "label": "1st-Order TF",
    "category": "Transfer Functions",
    "description": "K / (1 + T\u00b7s)",
    "inputs": ["u"],
    "outputs": ["y"],
    "color": "#2563eb",
    "dsl_lines": ["{{input}}", "{{output}}", "{{K}}", "{{T}}"],
    "args": [
      {"name": "K", "label": "Gain K", "type": "expr", "default": "1."},
      {"name": "T", "label": "Time constant T", "type": "expr", "default": "1."}
    ]
  },
  "tf1plim": {
    "label": "1st-Order TF + Limits",
    "category": "Transfer Functions",
    "description": "K / (1 + T\u00b7s) with constant output limits",
    "inputs": ["u"],
    "outputs": ["y"],
    "color": "#2563eb",
    "dsl_lines": ["{{input}}", "{{output}}", "{{K}}", "{{T}}", "{{lo}}", "{{hi}}"],
    "args": [
      {"name": "K",  "label": "Gain K",         "type": "expr", "default": "1."},
      {"name": "T",  "label": "Time constant T", "type": "expr", "default": "1."},
      {"name": "lo", "label": "Lower limit",     "type": "expr", "default": "-9999."},
      {"name": "hi", "label": "Upper limit",     "type": "expr", "default": "9999."}
    ]
  },
  "tf1pvlim": {
    "label": "1st-Order TF + Var Limits",
    "category": "Transfer Functions",
    "description": "K / (1 + T\u00b7s) with variable output limits (state names)",
