  "lim": {
    "label": "Limiter",
    "category": "Limiters",
    "description": "y = clamp(x, lo, hi) \u2014 constant bounds",
    "inputs": ["x"],
    "outputs": ["y"],
    "color": "#d97706",
    "dsl_lines": ["{{input}}", "{{output}}", "{{lo}}", "{{hi}}"],
    "args": [
      {"name": "lo", "label": "Lower limit", "type": "expr", "default": "0."},
      {"name": "hi", "label": "Upper limit", "type": "expr", "default": "1."}
    ]
  },
  "limvb": {
    "label": "Variable-Bound Limiter",
    "category": "Limiters",
    "description": "y = clamp(x, lo_state, hi_state)",
    "inputs": ["x"],
    "outputs": ["y"],
    "color": "#d97706",
    "dsl_lines": ["{{input}}", "{{lo_var}}", "{{hi_var}}", "{{output}}"],
    "args": [
      {"name": "lo_var", "label": "Lower limit state", "type": "state", "default": ""},
      {"name": "hi_var", "label": "Upper limit state", "type": "state", "default": ""}
    ]
  },
  "inlim": {
    "label": "Input Limiter",
    "category": "Limiters",
    "description": "Integrator with non-windup limits: T\u00b7dy/dt = x, clamped to [lo, hi]",
    "inputs": ["x"],
    "outputs": ["y"],
    "color": "#d97706",
    "dsl_lines": ["{{input}}", "{{output}}", "{{T}}", "{{lo}}", "{{hi}}"],
    "args": [
      {"name": "T",  "label": "Time constant T", "type": "expr", "default": "1."},
      {"name": "lo", "label": "Lower limit",     "type": "expr", "default": "0."},
      {"name": "hi", "label": "Upper limit",     "type": "expr", "default": "1."}
    ]
  },
  "invlim": {
    "label": "Integrator + Variable Limits",
    "category": "Limiters",
    "description": "Integrator with time constant T and non-windup limits. Both lower and upper limits are state variables. DSL order: input, lo_var, hi_var, output, T.",
    "inputs": ["u", "lo_var", "hi_var"],
    "outputs": ["y"],
    "color": "#d97706",
    "dsl_lines": ["{{input}}", "{{lo_var}}", "{{hi_var}}", "{{output}}", "{{T}}"],
    "args": [
      {"name": "lo_var", "label": "Lower limit (state)", "type": "state", "default": ""},
      {"name": "hi_var", "label": "Upper limit (state)", "type": "state", "default": ""},
      {"name": "T",      "label": "Time constant T",     "type": "expr",  "default": "1."}
    ]
  },
  "int": {
    "label": "Integrator",
    "category": "Controllers",
    "description": "Integrator with positive time constant T: T·dy/dt = u. T must be non-zero.",
    "inputs": ["u"],
    "outputs": ["y"],
    "color": "#16a34a",
    "dsl_lines": ["{{input}}", "{{output}}", "{{T}}"],
    "args": [
      {"name": "T", "label": "Time constant T", "type": "expr", "default": "1."}
    ]
  },
