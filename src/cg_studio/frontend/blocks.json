        "name": "K",
        "label": "Gain K",
        "type": "expr",
        "default": "1."
      },
      {
        "name": "T",
        "label": "Time constant T",
        "type": "expr",
        "default": "1."
      },
      {
        "name": "lo",
        "label": "Lower limit",
        "type": "expr",
        "default": "-9999."
      },
      {
        "name": "hi",
        "label": "Upper limit",
        "type": "expr",
        "default": "9999."
      }
    ]
  },
  "tf1pvlim": {
    "label": "1st-Order TF + Var Limits",
