  "abs": {
    "label": "Absolute Value",
    "category": "Nonlinear",
    "description": "y = |x|",
    "inputs": ["x"],
    "outputs": ["y"],
    "color": "#be185d",
    "dsl_lines": ["{{input}}", "{{output}}"],
    "args": []
  },
  "db": {
    "label": "Asymmetric Deadband",
    "category": "Nonlinear",
    "description": "Piecewise-linear deadband with independent lower/upper thresholds (delta1,delta2), slopes (s1,s2) and offsets (a1,a2). y = a1 + s1*(x-delta1) for x<delta1; y = 0 in the deadband; y = a2 + s2*(x-delta2) for x>delta2.",
    "inputs": ["x"],
    "outputs": ["y"],
    "color": "#be185d",
    "dsl_lines": ["{{input}}", "{{output}}", "{{delta1}}", "{{s1}}", "{{a1}}", "{{delta2}}", "{{s2}}", "{{a2}}"],
    "args": [
      {"name": "delta1", "label": "Lower threshold d1", "type": "expr", "default": "-0.05"},
      {"name": "s1",     "label": "Lower slope s1",     "type": "expr", "default": "1."},
      {"name": "a1",     "label": "Lower offset a1",    "type": "expr", "default": "0."},
      {"name": "delta2", "label": "Upper threshold d2", "type": "expr", "default": "0.05"},
      {"name": "s2",     "label": "Upper slope s2",     "type": "expr", "default": "1."},
      {"name": "a2",     "label": "Upper offset a2",    "type": "expr", "default": "0."}
    ]
  },
  "hyst": {
    "label": "Hysteresis",
    "category": "Nonlinear",
    "description": "Hysteresis loop defined by two thresholds (xI rising, xD falling) and two (yB,yA) output pairs. z0 selects the initial branch when starting inside the deadband.",
    "inputs": ["x"],
    "outputs": ["y"],
    "color": "#be185d",
    "dsl_lines": ["{{input}}", "{{output}}", "{{xI}}", "{{yIB}}", "{{yIA}}", "{{xD}}", "{{yDB}}", "{{yDA}}", "{{z0}}"],
    "args": [
      {"name": "xI",  "label": "Rising threshold xI",        "type": "expr", "default": "0.5"},
      {"name": "yIB", "label": "y before rising (yIB)",      "type": "expr", "default": "0."},
      {"name": "yIA", "label": "y after rising (yIA)",       "type": "expr", "default": "1."},
      {"name": "xD",  "label": "Falling threshold xD",       "type": "expr", "default": "-0.5"},
      {"name": "yDB", "label": "y before falling (yDB)",     "type": "expr", "default": "1."},
      {"name": "yDA", "label": "y after falling (yDA)",      "type": "expr", "default": "0."},
      {"name": "z0",  "label": "Initial branch z0 (>=0 upper, <0 lower)", "type": "expr", "default": "-1."}
    ]
  },
  "nint": {
    "label": "Nearest Integer",
    "category": "Nonlinear",
    "description": "y = nint(x + c) — integer nearest to the input shifted by a constant c",
