        "type": "expr",
        "default": "9999."
      },
      {
        "name": "xdotmin",
        "label": "Rate lower limit",
        "type": "expr",
        "default": "-9999."
      },
      {
        "name": "xdotmax",
        "label": "Rate upper limit",
        "type": "expr",
        "default": "9999."
      }
    ]
  },
  "tf1p2limr": {
    "label": "1st-Order TF + Rate+Output Limits + Reset",
