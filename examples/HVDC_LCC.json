{
  "model_type": "twop",
  "model_name": "HVDC_LCC",
  "data": [
    {
      "name": "p",
      "comment": "! number of poles (1 or 2)"
    },
    {
      "name": "rec_ctl",
      "comment": "! rectifier control : 1= current control, 2= power control, -1= alpha min control, 3=blocked (shut down)"
    },
    {
      "name": "inv_ctl",
      "comment": "! inverter control : 1= voltage control, 2= gamma control, -2= gamma min control,-1= reduced current control,3=blocked (shut down)"
    },
    {
      "name": "Br",
      "comment": "! number of bridges in series in rectifier"
    },
    {
      "name": "Bi",
      "comment": "! number of bridges in series in inverter"
    },
    {
      "name": "Er",
      "comment": "! phase-to-phase open-circuit voltage (kV) on DC side of rectifier transformer with 1 pu voltage on AC side"
    },
    {
      "name": "Ei",
      "comment": "! phase-to-phase open-circuit voltage (kV) on DC side of inverter transformer with 1 pu voltage on AC side"
    },
    {
      "name": "Rcr",
      "comment": "! rectifier commutating resistance per bridge (in ohm)"
    },
    {
      "name": "Xcr",
      "comment": "! rectifier commutating reactance per bridge (in ohm)"
    },
    {
      "name": "Rci",
      "comment": "! inverter commutating resistance per bridge (in ohm)"
    },
    {
      "name": "Xci",
      "comment": "! inverter commutating reactance per bridge (in ohm)"
    },
    {
      "name": "RL",
      "comment": "! DC line series resistance (ohm)"
    },
    {
      "name": "Rcomp",
      "comment": "! compounding resistance (voltage control by inverter) (ohm)"
    },
    {
      "name": "Tp",
      "comment": "! time constant of power control (s); not used if current is controlled"
    },
    {
      "name": "Idset",
      "comment": "! initial value (and setpoint if rec_ctl=1) of DC current (kA)"
    },
    {
      "name": "nr",
      "comment": "! initial rectifier transformer ratio(pu/pu)"
    },
    {
      "name": "ni",
      "comment": "! initial inverter transformer ratio (pu/pu) dIdt"
    }
  ],
  "parameters": [
    {
      "name": "Pset",
      "expr": "-([vx1]*[ix1]+[vy1]*[iy1])*sbase1",
      "continuation": false
    },
    {
      "name": "Vdr0",
      "expr": "{Pset}/({p}*{Idset})",
      "continuation": false
    },
    {
      "name": "alpha0",
      "expr": "dacos( ({nr}/(1.3504745*{Er}*dsqrt([vx1]**2+[vy1]**2))) * (({Vdr0}/{Br})+(0.9549297*{Xcr}+2*{Rcr})*{Idset}) )",
      "continuation": false
    },
    {
      "name": "mur0",
      "expr": "dacos( dcos({alpha0}) - 1.4142136*{Xcr}*{nr}*{Idset}/(dsqrt([vx1]**2+[vy1]**2)*{Er})) - {alpha0}",
      "continuation": false
    },
    {
      "name": "Qhvdc1",
      "expr": "{Pset}* (2.d0*{mur0}+dsin(2*{alpha0})-dsin(2d0*({mur0}+{alpha0})))/(dcos(2.d0*{alpha0})-dcos(2d0*({mur0}+{alpha0})))",
      "continuation": false
    },
    {
      "name": "B1",
      "expr": "({Qhvdc1}/sbase1-[vx1]*[iy1]+[vy1]*[ix1])/([vx1]**2+[vy1]**2)",
      "continuation": false
    },
    {
      "name": "Vdi0",
      "expr": "{Vdr0}-{RL}*{Idset}",
      "continuation": false
    },
    {
      "name": "gamma0",
      "expr": "dacos( ({ni}/(1.3504745*{Ei}*dsqrt([vx2]**2+[vy2]**2))) * (({Vdi0}/{Bi})+(0.9549297*{Xci}+2*{Rci})*{Idset}) )",
      "continuation": false
    },
    {
      "name": "mui0",
      "expr": "dacos( dcos({gamma0}) - 1.4142136*{Xci}*{ni}*{Idset}/(dsqrt([vx2]**2+[vy2]**2)*{Ei})) - {gamma0}",
      "continuation": false
    },
    {
      "name": "P2in",
      "expr": "{p}*{Vdi0}*{Idset}",
      "continuation": false
    },
    {
      "name": "G2",
      "expr": "({P2in}/sbase2-[vx2]*[ix2]-[vy2]*[iy2])/dsqrt([vx2]**2+[vy2]**2)",
      "continuation": false
    },
    {
      "name": "Qhvdc2",
      "expr": "{P2in}* (2.d0*{mui0}+dsin(2*{gamma0})-dsin(2d0*({mui0}+{gamma0})))/(dcos(2.d0*{gamma0})-dcos(2d0*({mui0}+{gamma0})))",
      "continuation": false
    },
    {
      "name": "B2",
      "expr": "({Qhvdc2}/sbase2-[vx2]*[iy2]+[vy2]*[ix2])/([vx2]**2+[vy2]**2)",
      "continuation": false
    },
    {
      "name": "Vset",
      "expr": "{Vdi0}+{Rcomp}*{Idset}",
      "continuation": false
    },
    {
      "name": "alphamin",
      "expr": "0.d0",
      "continuation": false
    },
    {
      "name": "Idred",
      "expr": "0.d0",
      "continuation": false
    },
    {
      "name": "gammamin",
      "expr": "0.d0",
      "continuation": false
    },
    {
      "name": "Td",
      "expr": "0.02",
      "continuation": false
    }
  ],
  "states": [
    {
      "name": "Vdr",
      "init": "{Vdr0}",
      "comment": "rectifier DC voltage (kV)"
    },
    {
      "name": "alpha",
      "init": "{alpha0}",
      "comment": "firing angle (rad)"
    },
    {
      "name": "mur",
      "init": "{mur0}",
      "comment": "overlap firing angle (rad)"
    },
    {
      "name": "Id",
      "init": "{Idset}",
