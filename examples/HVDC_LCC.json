    },
    {
      "name": "Vdi",
      "init": "{Vdi0}",
      "comment": "inverter DC voltage (kV)"
    },
    {
      "name": "gamma",
      "init": "{gamma0}",
      "comment": "extinction angle (rad)"
    },
    {
      "name": "mui",
      "init": "{mui0}",
      "comment": "overlap extinction angle (rad)"
    },
    {
      "name": "Ides",
      "init": "{Idset}",
      "comment": "DC current desired (kA)"
    },
    {
      "name": "Iord",
      "init": "{Idset}",
      "comment": "DC current order (kA)"
    },
    {
      "name": "P1",
      "init": "(-[vx1]*[ix1]-[vy1]*[iy1])*sbase1",
      "comment": "active power entering the link at rectifier end (pu)"
    },
    {
      "name": "Q1",
      "init": "([vx1]*[iy1]-[vy1]*[ix1])*sbase1",
      "comment": "reactive power entering the link at rectifier end (pu)"
    },
    {
      "name": "P2",
      "init": "([vx2]*[ix2]+[vy2]*[iy2])*sbase2",
      "comment": "active power exiting the link at inverter end (pu)"
    },
    {
      "name": "Q2",
      "init": "([vx2]*[iy2]-[vy2]*[ix2])*sbase2",
      "comment": "reactive power entering the link at rectifier end (pu)"
    },
    {
      "name": "V1",
